<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:MAUIAapp.Controls"
             x:Class="MAUIAapp.MainPage">

    <Grid RowDefinitions="Auto,*">
        <!-- UI controls in top row -->
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="30,0" Spacing="25">
                <Image
                    Source="dotnet_bot.png"
                    HeightRequest="185"
                    Aspect="AspectFit" />
                <Label Text="Hello, World!" Style="{StaticResource Headline}" />
                <Label Text="Welcome to &#10;.NET Multi-platform App UI"
                       Style="{StaticResource SubHeadline}" />
                <Button x:Name="CounterBtn" Text="Click me"
                        Clicked="OnCounterClicked"
                        HorizontalOptions="Fill" />
                <Button x:Name="StartSDLBtn" Text="Start SDL"
                        Clicked="OnStartSDLClicked"
                        HorizontalOptions="Fill" />
            </VerticalStackLayout>
        </ScrollView>

    </Grid>

</ContentPage>